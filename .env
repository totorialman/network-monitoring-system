# === ML Service ===
ML_SERVICE_URL=http://ml2-http-service:5000
ML_TIMEOUT=30s

# === ML Scoring ===
# Sigmoid parameters for progressive score transformation
# new_score = 1.0 / (1.0 + exp(-steepness * (old_score - midpoint)))
ML_SIGMOID_STEEPNESS=25.0
ML_SIGMOID_MIDPOINT=0.22

# Port scan: fixed severity=3, random ML score in range
ML_PORTSCAN_SCORE_MIN=0.30
ML_PORTSCAN_SCORE_MAX=0.80

# DDoS: random severity in [min, max], random ML score in range
ML_DDOS_SEVERITY_MIN=4
ML_DDOS_SEVERITY_MAX=5
ML_DDOS_SCORE_MIN=0.40
ML_DDOS_SCORE_MAX=0.95
